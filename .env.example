# Copy this file to .env and fill in your values
# Never commit .env to git

# Python backend (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://fitapp:fitapp_dev@localhost:5432/fitapp

# Auth service (Node.js pg driver) — uses postgres hostname inside Docker
AUTH_DATABASE_URL=postgresql://fitapp:fitapp_dev@postgres:5432/fitapp

# JWT — change this in production to a long random string
JWT_SECRET=dev-secret-change-in-prod

# OpenAI — required for diet and workout generation endpoints
OPENAI_API_KEY=sk-...

# OAuth — optional for local dev, leave empty to disable social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
